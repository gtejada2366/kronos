# --- Supabase (required for DB storage; analysis still runs without it) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# --- GitHub (optional but STRONGLY recommended) ---
# Unauthenticated GitHub API = 60 requests/hour, which is not enough to page
# through 180 days of commits/stars on a busy repo. A classic PAT with no
# scopes raises this to 5,000 requests/hour. Create one at:
# https://github.com/settings/tokens
GITHUB_TOKEN=

# --- CoinGecko (optional) ---
# A free "demo" API key raises rate limits and stability. Get one at:
# https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=
