# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=replace-with-a-long-random-string

# --- Anthropic (bot conversacional) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- WhatsApp Cloud API (Meta) ---
# Crea una app en https://developers.facebook.com → WhatsApp → setup
WHATSAPP_VERIFY_TOKEN=an-arbitrary-string-of-your-choice
# Token a nivel de aplicación; si tienes uno por número, configurarlo en clinics.whatsapp_access_token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_GRAPH_VERSION=v21.0

# --- Yape Empresas ---
# Si tienes API: pega creds aquí. Sin API, el sistema genera un link Yape
# del handle del comercio para cobro manual y verifica vía webhook simulado.
YAPE_MERCHANT_HANDLE=
YAPE_API_KEY=
